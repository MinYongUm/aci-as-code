# =============================================================================
# .ansible-lint — Ansible Lint 설정
# 위치: 프로젝트 루트
#
# ansible-lint 실행 시 이 파일을 자동으로 참조
# 참고: https://ansible.readthedocs.io/projects/lint/configuring/
# =============================================================================

# ---------------------------------------------------------------------------
# 프로파일: production → 엄격한 검사 (CI 환경 권장)
# basic     → 기본 검사
# moderate  → 중간
# safety    → 보안 관련 추가
# shared    → 공유 역할 배포 기준
# production→ 가장 엄격 (tag 필수 등)
# ---------------------------------------------------------------------------
profile: moderate  # production은 모든 task에 태그 필수 → moderate로 조정

# ---------------------------------------------------------------------------
# 무시할 규칙 (skip_list)
# 규칙 ID나 태그로 지정
# ---------------------------------------------------------------------------
skip_list:
  # yaml[truthy]: yamllint와 중복 검사, .yamllint로 통일
  - yaml[truthy]
  # name[casing]: task 이름 대소문자 강제 → 한국어/영어 혼용 시 불편
  - name[casing]
  # no-free-form: cisco.aci 모듈은 free-form 사용 안 하므로 불필요
  - no-free-form

# ---------------------------------------------------------------------------
# 경고만 표시하는 규칙 (warn_list)
# CI 실패가 아닌 경고로 처리
# ---------------------------------------------------------------------------
warn_list:
  # experimental: 실험적 규칙은 경고만
  - experimental
  # yaml[line-length]: 줄 길이는 .yamllint에서 관리
  - yaml[line-length]

# ---------------------------------------------------------------------------
# 검사 대상 제외 경로
# ---------------------------------------------------------------------------
exclude_paths:
  # vault 암호화 파일: 내용을 읽을 수 없으므로 제외
  - ansible/scenarios/01_basic_tenant/group_vars/all/vault.yml
  - ansible/scenarios/02_three_tier_app/group_vars/all/vault.yml
  # 의존성 설치 경로
  - .cache/
  - .git/

# ---------------------------------------------------------------------------
# 사용할 컬렉션 정의
# ansible-lint이 모듈 유효성 검사 시 참조
# ---------------------------------------------------------------------------
use_default_rules: true

# ---------------------------------------------------------------------------
# 태스크 파일 자동 인식 패턴
# ---------------------------------------------------------------------------
kinds:
  - tasks: 'ansible/roles/*/tasks/*.yml'
  - playbook: 'ansible/scenarios/*/site.yml'
  - vars: 'ansible/scenarios/*/group_vars/**/*.yml'
  - meta: 'ansible/roles/*/meta/*.yml'

# ---------------------------------------------------------------------------
# YAML 파일 인코딩
# ---------------------------------------------------------------------------
mock_modules:
  # cisco.aci 모듈은 실제 설치됨 → mock 불필요 (빈 리스트)
  []

# ---------------------------------------------------------------------------
# Loop 변수 이름 규칙
# with_items 대신 loop 권장 (ansible-lint 경고)
# ---------------------------------------------------------------------------
loop_var_prefix: ''  # 기본값 유지
