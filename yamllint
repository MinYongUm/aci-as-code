# =============================================================================
# .yamllint — YAML 린트 설정
# 위치: 프로젝트 루트
#
# yamllint 실행 시 이 파일을 자동으로 참조
# 규칙 수준: warn(경고) / error(오류) / disable(비활성화)
# =============================================================================

extends: default  # yamllint 기본 규칙 상속

rules:
  # ---------------------------------------------------------------------------
  # 줄 길이: 최대 120자
  # 기본값(80)은 Ansible task name이나 HCL description과 맞지 않아 120으로 확장
  # ---------------------------------------------------------------------------
  line-length:
    max: 120
    level: warning  # error 대신 warning → 포맷 유연성 확보

  # ---------------------------------------------------------------------------
  # 따옴표: 단일 따옴표 권장 (Ansible 관행)
  # 단, 이중 따옴표가 필요한 경우(변수 내 작은따옴표 포함)는 허용
  # ---------------------------------------------------------------------------
  quoted-strings:
    quote-type: single
    required: false  # 불필요한 따옴표 강제 없음

  # ---------------------------------------------------------------------------
  # 문서 시작 마커(---)
  # Ansible 플레이북은 관행적으로 --- 로 시작
  # require: false → 필수는 아님 (일부 파일에서 생략 허용)
  # ---------------------------------------------------------------------------
  document-start:
    present: true
    level: warning  # error 아님 → group_vars 등 예외 허용

  # ---------------------------------------------------------------------------
  # 빈 줄: 연속 빈 줄 최대 2개
  # ---------------------------------------------------------------------------
  empty-lines:
    max: 2
    max-start: 0
    max-end: 1

  # ---------------------------------------------------------------------------
  # 들여쓰기: 공백 2칸 (Ansible/YAML 표준)
  # ---------------------------------------------------------------------------
  indentation:
    spaces: 2
    indent-sequences: true
    check-multi-line-strings: false  # 멀티라인 문자열은 검사 제외

  # ---------------------------------------------------------------------------
  # 트루/폴스: 소문자 true/false 권장
  # Ansible 변수에서 True/False 혼용 방지
  # ---------------------------------------------------------------------------
  truthy:
    allowed-values:
      - 'true'
      - 'false'
    check-keys: false  # 키 이름(예: enable_routing)은 검사 제외

  # ---------------------------------------------------------------------------
  # 주석: 주석 뒤 공백 1개 이상 권장 (# comment)
  # ---------------------------------------------------------------------------
  comments:
    min-spaces-from-content: 1

  # ---------------------------------------------------------------------------
  # 콜론: 키: 값 사이 공백 1개
  # ---------------------------------------------------------------------------
  colons:
    max-spaces-before: 0
    max-spaces-after: 1

ignore: |
  # ansible-vault 암호화 파일 제외 (이진 데이터로 yamllint 오류 발생)
  ansible/scenarios/*/group_vars/all/vault.yml
  # .terraform 디렉토리 제외
  **/.terraform/**
